    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "a=range(-5,6,1)\n",
    "y=np.cosh(a)\n",
    "b=range(len(a))\n",
    "plt.plot(b,y,label=\"y=cosh(x)\")\n",
    "plt.title(\"Catenary\")\n",
    "plt.grid()\n",
    "plt.ylabel(\"y\")\n",
    "plt.xlabel(\"x\")\n",
    "plt.legend()\n",
    "plt.show()\n",
    "c=np.arange(-5,6,1)\n",
